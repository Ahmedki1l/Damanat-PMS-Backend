# Database (shared with PMS AI)
DATABASE_URL=postgresql://damanat:damanat@localhost:5432/damanat_db

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Camera password encryption key (32 hex bytes = 64 chars)
CAMERA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# PMS AI default base URL
PMS_AI_DEFAULT_URL=http://5.5.5.3:8080

# MongoDB (docker-compose up -d)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=damanat_pms
